# ─── Database ───────────────────────────────────────────
DB_HOST=database
DB_USER=msf_admin
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=metasploit_db

# ─── Authentication ────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_a_64_char_random_hex_string

# ─── Email Verification (optional) ─────────────────────
# If not set, verification codes are printed to backend console logs.
# Use a Gmail App Password: https://support.google.com/accounts/answer/185833
MAIL_USER=
MAIL_PASS=

# ─── Application ───────────────────────────────────────
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_strong_password_here
ALLOWED_ORIGIN=http://localhost
PORT=3000
